{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@aria-player/config": "workspace:*",
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "3.8.3",
    "stylelint": "^17.11.1",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "scripts": {
    "dev": "bun run --cwd packages/aria-player dev",
    "build": "bun run lint && bun run --cwd packages/aria-player build",
    "preview": "bun run --cwd packages/aria-player preview",
    "tauri": "bun run --cwd packages/aria-player tauri",
    "test": "bun run --cwd packages/aria-player test",
    "lint": "bun --filter '*' lint"
  },
  "prettier": {
    "semi": true,
    "printWidth": 80,
    "tabWidth": 2,
    "singleQuote": false,
    "trailingComma": "es5"
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard",
      "stylelint-config-css-modules"
    ],
    "ignoreFiles": [
      "**/dist/**",
      "**/target/**",
      "**/src-tauri/gen/**"
    ],
    "rules": {
      "selector-class-pattern": null,
      "custom-property-pattern": null
    }
  }
}
